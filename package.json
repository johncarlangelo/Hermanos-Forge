{
  "name": "hermanos-forge",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:start": "cross-env ELECTRON_START_URL=http://localhost:5173 electron .",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron:start\"",
    "electron:build": "npm run build && electron-builder",
    "package-backend": "py -m PyInstaller --noconsole --onefile --distpath ./dist_backend backend.py",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.hermanosforge.app",
    "productName": "Hermanos Forge",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "dist_backend",
        "to": "app.asar.unpacked/dist_backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "ffmpeg",
        "to": "app.asar.unpacked/ffmpeg",
        "filter": [
          "**/*"
        ]
      }
    ],
    "nsis": {
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src/assets/icon.ico"
    }
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "youtube-dl-exec": "^3.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
